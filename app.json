{
  "expo": {
    "name": "Kingdom Campus 2026",
    "slug": "kingdom-campus-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#1A237E",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#1A237E",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kingdomcampus.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1A237E"
      },
      "package": "com.kingdomcampus.app",
      "permissions": []
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "themeColor": "#1A237E"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "enableProguardInReleaseBuilds": true,
            "enableShrinkResourcesInReleaseBuilds": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "df693892-437a-46f1-be25-d60dd244bd94"
      }
    }
  }
}
