{
  "expo": {
    "name": "Kingdom Campus 2026",
    "slug": "kingdom-campus-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "#1A237E",
    "splash": {
      "image": "./assets/splash-icon.png",
      "backgroundColor": "#1A237E",
      "resizeMode": "contain"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kingdomcampus.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1A237E"
      },
      "package": "com.kingdomcampus.app",
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "SCHEDULE_EXACT_ALARM",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "themeColor": "#1A237E"
    },
    "plugins": []
  }
}

